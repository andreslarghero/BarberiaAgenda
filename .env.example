PORT=3000
JWT_SECRET="your_jwt_secret_here"
JWT_EXPIRES_IN="1d"

# =============================================================================
# Postgres / Supabase — DATABASE_URL
# =============================================================================
# Obtené las cadenas en: Supabase Dashboard → tu proyecto → Connect (o Settings → Database).
#
# Formato directo (puerto 5432) — válido para Prisma con sslmode=require:
#   postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public&sslmode=require
#
# Si Prisma / Node devuelve "Can't reach database server" (P1001) a db.*.supabase.co:5432:
# - Proyecto pausado (plan free): reactivalo desde el Dashboard.
# - Red local / ISP / firewall bloqueando 5432 o sin ruta IPv6: usá el pooler que muestra "Connect".
# - Contraseña con caracteres especiales: codificá la contraseña en la URL (URL encoding).
#
# Recomendación Supabase + Prisma: si la conexión directa no responde, usá Transaction pooler
# (puerto 6543) copiada del dashboard y agregá pgbouncer=true si corresponde:
#   ...pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
#
# Guía oficial: https://supabase.com/docs/guides/database/prisma
# =============================================================================

DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?schema=public&pgbouncer=true&sslmode=require"
