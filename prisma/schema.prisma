generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  BARBER
  CLIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model User {
  id           Int       @id @default(autoincrement()) @map("id")
  fullName     String    @map("full_name")
  email        String    @unique @map("email")
  passwordHash String    @map("password_hash")
  role         UserRole  @default(ADMIN) @map("role")
  barberId     Int?      @unique @map("barber_id")
  clientId     Int?      @unique @map("client_id")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  appointments Appointment[] @relation("AppointmentCreatedBy")
  barber       Barber?       @relation(fields: [barberId], references: [id], onDelete: SetNull)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@map("users")
}

model Barber {
  id          Int      @id @default(autoincrement()) @map("id")
  fullName    String   @map("full_name")
  phone       String?  @map("phone")
  email       String?  @unique @map("email")
  notes       String?  @map("notes")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  appointments Appointment[]
  user         User?
  schedules    BarberSchedule[]
  blockedTimes BlockedTime[]

  @@map("barbers")
}

model Client {
  id           Int      @id @default(autoincrement()) @map("id")
  fullName     String   @map("full_name")
  phone        String   @map("phone")
  email        String?  @unique @map("email")
  notes        String?  @map("notes")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  appointments Appointment[]
  user         User?

  @@map("clients")
}

model Service {
  id           Int      @id @default(autoincrement()) @map("id")
  name         String   @unique @map("name")
  description  String?  @map("description")
  durationMin  Int      @map("duration_min")
  price        Decimal  @db.Decimal(10, 2) @map("price")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  appointments Appointment[]

  @@map("services")
}

model Appointment {
  id           Int               @id @default(autoincrement()) @map("id")
  barberId     Int               @map("barber_id")
  clientId     Int               @map("client_id")
  serviceId    Int               @map("service_id")
  createdById  Int               @map("created_by_id")
  startsAt     DateTime          @map("starts_at")
  endsAt       DateTime          @map("ends_at")
  status       AppointmentStatus @default(PENDING) @map("status")
  reminder24hSent Boolean        @default(false) @map("reminder_24h_sent")
  reminder2hSent  Boolean        @default(false) @map("reminder_2h_sent")
  notes        String?           @map("notes")
  cancelReason String?           @map("cancel_reason")
  cancelledAt  DateTime?         @map("cancelled_at")
  completedAt  DateTime?         @map("completed_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  barber    Barber  @relation(fields: [barberId], references: [id], onDelete: Restrict)
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  createdBy User    @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@map("appointments")
}

model BarberSchedule {
  id           Int      @id @default(autoincrement()) @map("id")
  barberId     Int      @map("barber_id")
  dayOfWeek    Int      @map("day_of_week")
  startTime    String   @map("start_time")
  endTime      String   @map("end_time")
  isWorkingDay Boolean  @default(true) @map("is_working_day")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@map("barber_schedules")
}

model BlockedTime {
  id          Int      @id @default(autoincrement()) @map("id")
  barberId    Int      @map("barber_id")
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  reason      String?  @map("reason")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@map("blocked_times")
}

model BusinessSettings {
  id                    Int      @id @map("id")
  businessName          String   @default("Agenda Barberia") @map("business_name")
  currency              String   @default("ARS") @map("currency")
  defaultCommissionRate Decimal  @default(0.4) @db.Decimal(5, 4) @map("default_commission_rate")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("business_settings")
}
